# ============================================================
# 环境变量模板
# 复制本文件为 .env 并填入真实值
#   cp .env.example .env
#
# .env 已在 .gitignore 中排除，不会被提交到 GitHub
# ============================================================

# ============================================================
# 阿里云 Quick BI
# ============================================================
QBI_ACCESS_KEY=your_access_key_here
QBI_SECRET_KEY=your_secret_key_here

# ============================================================
# 飞书 — 催收业务主应用（cli_aaab85f1c1791bd5）
# 用途：首逾预警、每日案件预估、日报周报
# ============================================================
FEISHU_COLLECTION_APP_ID=cli_xxx
FEISHU_COLLECTION_APP_SECRET=xxx

# ============================================================
# 飞书 — 同步/部署应用（cli_aaab8acc6d38dbc3）
# 用途：飞书文档同步、案件预估部署
# ============================================================
FEISHU_SYNC_APP_ID=cli_xxx
FEISHU_SYNC_APP_SECRET=xxx

# ============================================================
# 催收系统 Token — 阿根廷（middlela.com）
# ============================================================
ARG_COLLECT_TOKEN=xxx

# ============================================================
# 催收系统 Token — 墨西哥（maxicredito.loan）
# ============================================================
MEX_COLLECT_TOKEN=xxx

# ============================================================
# Redash
# ============================================================
REDASH_EMAIL=xxx@xxx.com
REDASH_PASSWORD=xxx

# ============================================================
# 飞书群聊 Chat ID（可选，不在本次迁移范围）
# ============================================================
# FEISHU_CHAT_MX=oc_xxx
# FEISHU_CHAT_AR=oc_xxx
# FEISHU_REVIEWER_OPEN_ID=ou_xxx
# FEISHU_DIRECTOR_OPEN_ID=ou_xxx
