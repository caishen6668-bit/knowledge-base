{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83c\udfe0 \u6b22\u8fce\u6765\u5230\u6211\u7684\u77e5\u8bc6\u5e93","text":"<p>\ud83d\udcdd \u8bb0\u5f55\u3001\u6574\u7406\u3001\u590d\u7528 \u2014 \u8fd9\u662f\u6211\u7684\u4e2a\u4eba\u77e5\u8bc6\u7ba1\u7406\u7a7a\u95f4\u3002</p>"},{"location":"#_2","title":"\ud83d\udccb \u5feb\u901f\u5bfc\u822a","text":"<ul> <li>\ud83d\udcda \u5b66\u4e60\u7b14\u8bb0 \u2014 \u5b66\u4e60\u8fc7\u7a0b\u4e2d\u7684\u5fc3\u5f97\u3001\u603b\u7ed3\u548c\u7b14\u8bb0</li> <li>\ud83d\udcbb \u6280\u672f\u6587\u6863 \u2014 \u5f00\u53d1\u73af\u5883\u3001\u5de5\u5177\u914d\u7f6e\u3001\u5e38\u7528\u547d\u4ee4</li> <li>\ud83d\udcd6 \u53c2\u8003\u8d44\u6599 \u2014 \u5b9e\u7528\u5de5\u5177\u3001\u5b66\u4e60\u8d44\u6e90\u3001\u6536\u85cf\u94fe\u63a5</li> <li>\ud83c\udff7\ufe0f \u6807\u7b7e \u2014 \u6309\u6807\u7b7e\u6d4f\u89c8\u6240\u6709\u5185\u5bb9</li> </ul>"},{"location":"#_3","title":"\u2728 \u6700\u8fd1\u66f4\u65b0","text":""},{"location":"#_4","title":"\u4f7f\u7528\u6307\u5357","text":"<ul> <li>\u4e86\u89e3\u5982\u4f55 \u5feb\u901f\u4e0a\u624b \u4f7f\u7528\u6b64\u77e5\u8bc6\u5e93</li> <li>\u67e5\u770b \u6700\u4f73\u5b9e\u8df5 \u4e86\u89e3\u5982\u4f55\u9ad8\u6548\u7ba1\u7406\u77e5\u8bc6</li> </ul>"},{"location":"#_5","title":"\u6280\u672f\u6587\u6863","text":"<ul> <li>\u73af\u5883\u642d\u5efa \u2014 \u5f00\u53d1\u73af\u5883\u914d\u7f6e\u8bb0\u5f55</li> <li>\u5e38\u7528\u547d\u4ee4 \u2014 \u5e38\u7528\u547d\u4ee4\u901f\u67e5</li> </ul>"},{"location":"#_6","title":"\ud83c\udfaf \u4f7f\u7528\u5efa\u8bae","text":"<p>\u8ba9\u77e5\u8bc6\u5e93\u53d1\u6325\u6700\u5927\u4ef7\u503c</p> <ol> <li>\u968f\u624b\u8bb0\u5f55 \u2014 \u9047\u5230\u6709\u4ef7\u503c\u7684\u4fe1\u606f\u7acb\u5373\u8bb0\u4e0b</li> <li>\u5b9a\u671f\u6574\u7406 \u2014 \u6bcf\u5468\u82b1 10 \u5206\u949f\u5206\u7c7b\u6574\u7406</li> <li>\u5173\u8054\u601d\u8003 \u2014 \u7528\u94fe\u63a5\u5c06\u4e0d\u540c\u77e5\u8bc6\u70b9\u4e32\u8054</li> <li>\u590d\u4e60\u56de\u987e \u2014 \u5b9a\u671f\u7ffb\u9605\u65e7\u7b14\u8bb0\u52a0\u6df1\u8bb0\u5fc6</li> </ol>"},{"location":"#_7","title":"\ud83d\udcca \u77e5\u8bc6\u5206\u7c7b","text":"\u7c7b\u522b \u8bf4\u660e \u66f4\u65b0\u9891\u7387 \ud83d\udcda \u5b66\u4e60\u7b14\u8bb0 \u8bfe\u7a0b\u3001\u4e66\u7c4d\u3001\u6587\u7ae0\u7684\u5b66\u4e60\u603b\u7ed3 \u7ecf\u5e38 \ud83d\udcbb \u6280\u672f\u6587\u6863 \u5f00\u53d1\u5de5\u5177\u3001\u6846\u67b6\u3001\u8bed\u8a00\u76f8\u5173 \u6309\u9700 \ud83d\udcd6 \u53c2\u8003\u8d44\u6599 \u5de5\u5177\u94fe\u3001\u8d44\u6e90\u94fe\u63a5\u3001\u901f\u67e5\u8868 \u6301\u7eed <p>\u77e5\u8bc6\u5c31\u662f\u529b\u91cf \u2014\u2014 \u5f17\u6717\u897f\u65af\u00b7\u57f9\u6839</p>"},{"location":"tags/","title":"\ud83c\udff7\ufe0f \u6807\u7b7e","text":"<p>\u4ee5\u4e0b\u662f\u6240\u6709\u5185\u5bb9\u7684\u6807\u7b7e\u7d22\u5f15\u3002</p> <p>[TAGS]</p>"},{"location":"dev/","title":"\ud83d\udcbb \u6280\u672f\u6587\u6863","text":"<p>\u6280\u672f\u5f00\u53d1\u76f8\u5173\u7684\u6587\u6863\u548c\u7b14\u8bb0\u3002</p>"},{"location":"dev/#_2","title":"\u5206\u7c7b","text":"<ul> <li>\u73af\u5883\u642d\u5efa \u2014 \u5f00\u53d1\u73af\u5883\u914d\u7f6e\u8bb0\u5f55</li> <li>\u5e38\u7528\u547d\u4ee4 \u2014 \u5e38\u7528\u547d\u4ee4\u901f\u67e5\u8868</li> </ul> <p>\u5efa\u8bae</p> <p>\u9047\u5230\u91cd\u590d\u64cd\u4f5c\u65f6\uff0c\u628a\u6b65\u9aa4\u8bb0\u5f55\u4e0b\u6765\uff0c\u4e0b\u6b21\u5c31\u80fd\u76f4\u63a5\u590d\u5236\u6267\u884c\u3002</p>"},{"location":"dev/commands/","title":"\u26a1 \u5e38\u7528\u547d\u4ee4\u901f\u67e5","text":""},{"location":"dev/commands/#git","title":"Git","text":"<pre><code># \u514b\u9686\u4ed3\u5e93\ngit clone &lt;repository-url&gt;\n\n# \u67e5\u770b\u72b6\u6001\ngit status\n\n# \u6dfb\u52a0\u6587\u4ef6\ngit add .\ngit add &lt;file&gt;\n\n# \u63d0\u4ea4\ngit commit -m \"\u63d0\u4ea4\u4fe1\u606f\"\n\n# \u63a8\u9001\u5230\u8fdc\u7a0b\ngit push origin main\n\n# \u62c9\u53d6\u66f4\u65b0\ngit pull origin main\n</code></pre>"},{"location":"dev/commands/#mkdocs","title":"MkDocs","text":"<pre><code># \u542f\u52a8\u672c\u5730\u670d\u52a1\nmkdocs serve\n\n# \u6784\u5efa\u9759\u6001\u7ad9\u70b9\nmkdocs build\n\n# \u90e8\u7f72\u5230 GitHub Pages\nmkdocs gh-deploy\n</code></pre>"},{"location":"dev/commands/#python","title":"Python","text":"<pre><code># \u5b89\u88c5\u4f9d\u8d56\npip install &lt;package&gt;\n\n# \u5bfc\u51fa\u4f9d\u8d56\npip freeze &gt; requirements.txt\n\n# \u5b89\u88c5\u4f9d\u8d56\uff08\u4ece\u6587\u4ef6\uff09\npip install -r requirements.txt\n</code></pre>"},{"location":"dev/setup/","title":"\ud83d\udd27 \u73af\u5883\u642d\u5efa","text":""},{"location":"dev/setup/#python","title":"Python \u73af\u5883","text":""},{"location":"dev/setup/#python_1","title":"\u5b89\u88c5 Python","text":"<p>\u4ece python.org \u4e0b\u8f7d\u5b89\u88c5\u5305\u3002</p>"},{"location":"dev/setup/#_2","title":"\u521b\u5efa\u865a\u62df\u73af\u5883","text":"<pre><code>python -m venv .venv\n</code></pre>"},{"location":"dev/setup/#_3","title":"\u6fc0\u6d3b\u865a\u62df\u73af\u5883","text":"WindowsmacOS / Linux <pre><code>.venv\\Scripts\\activate\n</code></pre> <pre><code>source .venv/bin/activate\n</code></pre>"},{"location":"dev/setup/#nodejs","title":"Node.js \u73af\u5883","text":""},{"location":"dev/setup/#nodejs_1","title":"\u5b89\u88c5 Node.js","text":"<p>\u4ece nodejs.org \u4e0b\u8f7d LTS \u7248\u672c\u3002</p>"},{"location":"dev/setup/#_4","title":"\u9a8c\u8bc1\u5b89\u88c5","text":"<pre><code>node --version\nnpm --version\n</code></pre>"},{"location":"dev/setup/#git","title":"Git \u914d\u7f6e","text":"<pre><code>git config --global user.name \"Your Name\"\ngit config --global user.email \"your.email@example.com\"\n</code></pre>"},{"location":"guide/","title":"\ud83d\udcda \u5b66\u4e60\u7b14\u8bb0","text":"<p>\u8fd9\u91cc\u662f\u5b66\u4e60\u7b14\u8bb0\u7684\u6982\u89c8\u9875\u9762\uff0c\u8bb0\u5f55\u5b66\u4e60\u8fc7\u7a0b\u4e2d\u7684\u77e5\u8bc6\u70b9\u3001\u5fc3\u5f97\u548c\u603b\u7ed3\u3002</p>"},{"location":"guide/#_2","title":"\u5185\u5bb9\u5206\u7c7b","text":"<ul> <li>\u5feb\u901f\u5f00\u59cb \u2014 \u77e5\u8bc6\u5e93\u4f7f\u7528\u5165\u95e8</li> <li>\u6700\u4f73\u5b9e\u8df5 \u2014 \u77e5\u8bc6\u7ba1\u7406\u7684\u6700\u4f73\u5b9e\u8df5</li> </ul> <p>\u6301\u7eed\u66f4\u65b0\u4e2d</p> <p>\u8fd9\u4e2a\u7248\u5757\u7684\u5185\u5bb9\u4f1a\u968f\u7740\u5b66\u4e60\u8fdb\u5ea6\u4e0d\u65ad\u8865\u5145\u548c\u5b8c\u5584\u3002</p>"},{"location":"guide/best-practices/","title":"\ud83c\udf1f \u6700\u4f73\u5b9e\u8df5","text":""},{"location":"guide/best-practices/#_2","title":"\u77e5\u8bc6\u7ba1\u7406\u539f\u5219","text":""},{"location":"guide/best-practices/#1","title":"1. \u539f\u5b50\u5316","text":"<p>\u6bcf\u6761\u7b14\u8bb0\u53ea\u8bb0\u5f55\u4e00\u4e2a\u77e5\u8bc6\u70b9\uff0c\u4fbf\u4e8e\u7d22\u5f15\u548c\u590d\u7528\u3002</p> <ul> <li>\u2705 \u597d\u4f8b\u5b50: <code>Python \u5217\u8868\u63a8\u5bfc\u5f0f.md</code></li> <li>\u274c \u574f\u4f8b\u5b50: <code>Python \u5404\u79cd\u9ad8\u7ea7\u7279\u6027.md</code></li> </ul>"},{"location":"guide/best-practices/#2","title":"2. \u94fe\u63a5\u601d\u7ef4","text":"<p>\u5229\u7528 Markdown \u94fe\u63a5\u5c06\u76f8\u5173\u77e5\u8bc6\u4e32\u8054\u8d77\u6765\uff1a</p> <pre><code>\u4e86\u89e3\u66f4\u591a\u5173\u4e8e [Python \u88c5\u9970\u5668](../dev/python-decorators.md) \u7684\u5185\u5bb9\n</code></pre>"},{"location":"guide/best-practices/#3","title":"3. \u5b9a\u671f\u6574\u7406","text":"<ul> <li>\u6bcf\u65e5: \u968f\u624b\u8bb0\u5f55\u65b0\u77e5\u8bc6</li> <li>\u6bcf\u5468: \u5206\u7c7b\u6574\u7406\u3001\u6dfb\u52a0\u6807\u7b7e</li> <li>\u6bcf\u6708: \u590d\u4e60\u56de\u987e\u3001\u66f4\u65b0\u8fc7\u65f6\u5185\u5bb9</li> </ul>"},{"location":"guide/best-practices/#_3","title":"\u7b14\u8bb0\u6a21\u677f","text":"<pre><code>---\ntags:\n  - tag1\n  - tag2\n---\n\n# \u6807\u9898\n\n## \u6982\u8ff0\n\n\u7b80\u8981\u63cf\u8ff0\u8fd9\u4e2a\u77e5\u8bc6\u70b9\n\n## \u6838\u5fc3\u5185\u5bb9\n\n- \u8981\u70b9 1\n- \u8981\u70b9 2\n\n## \u4ee3\u7801\u793a\u4f8b\n\n```python\nprint(\"Hello\")\n</code></pre>"},{"location":"guide/best-practices/#_4","title":"\u53c2\u8003\u8d44\u6599","text":"<ul> <li>\u94fe\u63a5\u6807\u9898 <pre><code>## \u76ee\u5f55\u7ed3\u6784\u5efa\u8bae\n</code></pre> docs/ \u251c\u2500\u2500 index.md              # \u9996\u9875 \u251c\u2500\u2500 guide/                # \u4f7f\u7528\u6307\u5357 \u2502   \u251c\u2500\u2500 index.md \u2502   \u2514\u2500\u2500 getting-started.md \u251c\u2500\u2500 dev/                  # \u6280\u672f\u5f00\u53d1 \u2502   \u251c\u2500\u2500 index.md \u2502   \u251c\u2500\u2500 python/ \u2502   \u251c\u2500\u2500 javascript/ \u2502   \u2514\u2500\u2500 docker/ \u251c\u2500\u2500 reference/            # \u53c2\u8003\u8d44\u6599 \u2502   \u2514\u2500\u2500 index.md \u2514\u2500\u2500 tags.md               # \u6807\u7b7e\u9875\u9762 ```</li> </ul>"},{"location":"guide/getting-started/","title":"\ud83d\ude80 \u5feb\u901f\u5f00\u59cb","text":""},{"location":"guide/getting-started/#mkdocs","title":"\u4ec0\u4e48\u662f MkDocs\uff1f","text":"<p>MkDocs \u662f\u4e00\u4e2a\u5feb\u901f\u3001\u7b80\u5355\u7684\u9759\u6001\u7ad9\u70b9\u751f\u6210\u5668\uff0c\u4e13\u4e3a\u9879\u76ee\u6587\u6863\u8bbe\u8ba1\u3002\u5b83\u4f7f\u7528 Markdown \u7f16\u5199\u5185\u5bb9\uff0c\u751f\u6210\u6f02\u4eae\u7684 HTML \u9875\u9762\u3002</p>"},{"location":"guide/getting-started/#_2","title":"\u5982\u4f55\u6dfb\u52a0\u5185\u5bb9","text":""},{"location":"guide/getting-started/#1-markdown","title":"1. \u521b\u5efa\u65b0\u7684 Markdown \u6587\u4ef6","text":"<p>\u5728 <code>docs/</code> \u76ee\u5f55\u4e0b\u521b\u5efa <code>.md</code> \u6587\u4ef6\uff0c\u4f8b\u5982\uff1a</p> <pre><code># \u6211\u7684\u65b0\u7b14\u8bb0\n\n\u8fd9\u662f\u7b14\u8bb0\u5185\u5bb9\uff0c\u652f\u6301 **\u7c97\u4f53**\u3001*\u659c\u4f53*\u3001~~\u5220\u9664\u7ebf~~ \u7b49\u683c\u5f0f\u3002\n\n## \u4e8c\u7ea7\u6807\u9898\n\n- \u5217\u8868\u9879 1\n- \u5217\u8868\u9879 2\n</code></pre>"},{"location":"guide/getting-started/#2","title":"2. \u6ce8\u518c\u5bfc\u822a","text":"<p>\u5728 <code>mkdocs.yml</code> \u7684 <code>nav</code> \u90e8\u5206\u6dfb\u52a0\u6587\u4ef6\u8def\u5f84\uff1a</p> <pre><code>nav:\n  - \u65b0\u7b14\u8bb0: path/to/your-file.md\n</code></pre>"},{"location":"guide/getting-started/#3","title":"3. \u67e5\u770b\u6548\u679c","text":"<p>\u542f\u52a8\u672c\u5730\u670d\u52a1\u540e\uff0c\u6d4f\u89c8\u5668\u4f1a\u81ea\u52a8\u5237\u65b0\u663e\u793a\u65b0\u5185\u5bb9\u3002</p>"},{"location":"guide/getting-started/#markdown","title":"\u5e38\u7528 Markdown \u8bed\u6cd5","text":""},{"location":"guide/getting-started/#_3","title":"\u63d0\u793a\u5757","text":"<pre><code>!!! tip \"\u63d0\u793a\u6807\u9898\"\n    \u8fd9\u662f\u63d0\u793a\u5185\u5bb9\uff0c\u652f\u6301\u591a\u6bb5\u843d\u3002\n\n!!! warning \"\u8b66\u544a\"\n    \u6ce8\u610f\uff1a\u8fd9\u662f\u4e00\u4e2a\u8b66\u544a\u4fe1\u606f\u3002\n\n!!! danger \"\u5371\u9669\"\n    \u8fd9\u662f\u4e00\u4e2a\u5371\u9669\u63d0\u793a\uff01\n</code></pre> <p>\u6548\u679c\uff1a</p> <p>\u63d0\u793a</p> <p>\u8fd9\u662f\u63d0\u793a\u5757\u7684\u6548\u679c</p>"},{"location":"guide/getting-started/#_4","title":"\u4ee3\u7801\u5757","text":"<pre><code>```python\ndef hello():\n    print(\"Hello, World!\")\n```\n</code></pre>"},{"location":"guide/getting-started/#_5","title":"\u4efb\u52a1\u5217\u8868","text":"<pre><code>- [x] \u5df2\u5b8c\u6210\u4efb\u52a1\n- [ ] \u672a\u5b8c\u6210\u4efb\u52a1\n</code></pre>"},{"location":"guide/getting-started/#_6","title":"\u8868\u683c","text":"<pre><code>| \u540d\u79f0 | \u8bf4\u660e | \u7248\u672c |\n|:---|:---|:---:|\n| Python | \u7f16\u7a0b\u8bed\u8a00 | 3.13 |\n| MkDocs | \u6587\u6863\u5de5\u5177 | 1.6 |\n</code></pre>"},{"location":"guide/getting-started/#_7","title":"\u6807\u7b7e\u9875","text":"<pre><code>=== \"Windows\"\n    Windows \u7cfb\u7edf\u7684\u64cd\u4f5c\u8bf4\u660e\n\n=== \"macOS\"\n    macOS \u7cfb\u7edf\u7684\u64cd\u4f5c\u8bf4\u660e\n\n=== \"Linux\"\n    Linux \u7cfb\u7edf\u7684\u64cd\u4f5c\u8bf4\u660e\n</code></pre>"},{"location":"guide/getting-started/#_8","title":"\u672c\u5730\u9884\u89c8","text":"<pre><code>cd D:/knowledge-base\n.venv/Scripts/mkdocs serve\n</code></pre> <p>\u7136\u540e\u5728\u6d4f\u89c8\u5668\u4e2d\u6253\u5f00 <code>http://127.0.0.1:8000</code> \u5373\u53ef\u9884\u89c8\u3002</p>"},{"location":"reference/","title":"\ud83d\udcd6 \u53c2\u8003\u8d44\u6599","text":"<p>\u5e38\u7528\u5de5\u5177\u3001\u8d44\u6e90\u548c\u94fe\u63a5\u6c47\u603b\u3002</p>"},{"location":"reference/#_2","title":"\u5feb\u901f\u94fe\u63a5","text":"<ul> <li>\u5b9e\u7528\u5de5\u5177 \u2014 \u63a8\u8350\u7684\u5de5\u5177\u548c\u8f6f\u4ef6</li> <li>\u5b66\u4e60\u8d44\u6e90 \u2014 \u4f18\u8d28\u5b66\u4e60\u8d44\u6e90</li> </ul> <p>\u6301\u7eed\u66f4\u65b0</p> <p>\u9047\u5230\u597d\u7528\u7684\u5de5\u5177\u548c\u8d44\u6e90\uff0c\u968f\u65f6\u6dfb\u52a0\u5230\u8fd9\u91cc\u3002</p>"},{"location":"reference/resources/","title":"\ud83d\udcda \u5b66\u4e60\u8d44\u6e90","text":""},{"location":"reference/resources/#_2","title":"\u7f16\u7a0b\u5b66\u4e60","text":"\u8d44\u6e90 \u8bf4\u660e \u94fe\u63a5 Python \u5b98\u65b9\u6587\u6863 Python \u6743\u5a01\u53c2\u8003 \u94fe\u63a5 MDN Web Docs Web \u6280\u672f\u6587\u6863 \u94fe\u63a5 W3Schools \u7f16\u7a0b\u5165\u95e8\u6559\u7a0b \u94fe\u63a5"},{"location":"reference/resources/#_3","title":"\u8ba1\u7b97\u673a\u79d1\u5b66","text":"<ul> <li>CS50 \u2014 \u54c8\u4f5b\u5927\u5b66\u8ba1\u7b97\u673a\u79d1\u5b66\u5bfc\u8bba</li> <li>Missing Semester \u2014 MIT \u8ba1\u7b97\u673a\u6559\u80b2\u7f3a\u5931\u7684\u4e00\u8bfe</li> </ul>"},{"location":"reference/resources/#ai","title":"AI / \u673a\u5668\u5b66\u4e60","text":"<ul> <li>Fast.ai \u2014 \u5b9e\u7528\u7684\u6df1\u5ea6\u5b66\u4e60\u8bfe\u7a0b</li> <li>Hugging Face \u2014 AI \u6a21\u578b\u548c\u6570\u636e\u96c6\u5e73\u53f0</li> </ul>"},{"location